# Public URL. Telegram Mini App uchun real HTTPS domen kerak.
# Render/Railway/Vercel kabi hostinglarda bo‘lsa server o‘zi autodetect qiladi.
PUBLIC_URL=https://kard2.onrender.com
WEBAPP_URL=https://kard2.onrender.com

# Telegram BotFather tokeni
BOT_TOKEN=8590837317:AAG3zEIHo3wvtd9NeIqVi__Fyit2rqhaHvI
ADMIN_TELEGRAM_CHAT_ID=

# Productionda true qiling. Lokal test uchun false qoldirilgan.
REQUIRE_TELEGRAM_AUTH=false
INIT_DATA_MAX_AGE_SECONDS=86400

# Telegram bot ishlashi uchun: webhook avtomatik sozlanadi, agar PUBLIC_URL real HTTPS bo‘lsa.
AUTO_SET_WEBHOOK=true
# VPS/lokal test uchun polling ishlating: TELEGRAM_POLLING=true; production webhook uchun false.
TELEGRAM_POLLING=false
# Ixtiyoriy webhook secret; bo‘sh qoldirish mumkin.
TELEGRAM_WEBHOOK_SECRET=

